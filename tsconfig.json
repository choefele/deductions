{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "allowJs": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noImplicitAny": true,
    "strict": true,
    "jsx": "react-jsx",
    "sourceMap": true,
    "outDir": "dist",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["app/renderer/*"]
    },
    "types": ["vite/client", "vitest"]
  },
  "include": [
    "forge.env.d.ts",
    "app/**/*.ts",
    "app/**/*.tsx",
    "tests/**/*.ts",
    "*.config.ts"
  ]
}
